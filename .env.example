# Frontend Environment Variables
# NOTE: For security, do NOT put production OpenAI or other long-lived API keys in
# client-side env files. Prefer to call the backend which holds secrets.
OPENAI_API_KEY=your_openai_api_key_here  # Only for local dev; remove for production
FDA_API_KEY=your_openfda_api_key_here    # Optional but recommended
PUBMED_EMAIL=your_email@example.com     # For PubMed API attribution

# Backend Environment Variables
# For production, store secrets in Secret Manager and inject into Cloud Run.
DATABASE_URL=postgresql+pg8000://user:password@/dbname?unix_sock=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME/.s.PGSQL.5432
GCP_PROJECT_ID=your_gcp_project_id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json  # only for local dev
GCP_PROJECT_NUMBER=your_project_number  # used by secret_loader to build secret paths

# Flask / App Config
FLASK_ENV=development
FLASK_APP=main.py